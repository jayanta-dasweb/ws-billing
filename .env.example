# =============================================================================
# Billing POS — copy to `.env` at repo root:  cp .env.example .env
# All keys below are used by the app. Secrets may differ; keep the same keys.
# =============================================================================

# --- App ---
NODE_ENV=development
APP_NAME=Billing System

# --- Backend API ---
BACKEND_PORT=4000
API_PREFIX=api
API_VERSION=v1
JWT_ACCESS_SECRET=dev-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
COOKIE_SECURE=false
IP_ALLOWLIST_ENFORCED=false
COUNTER_SESSION_TTL_SEC=28800

# --- MySQL (matches docker-compose mysql service) ---
DATABASE_URL=mysql://billing:billing_secret@localhost:3306/billing_db
# Only for `prisma migrate dev` (optional — use `npm run prisma:deploy` for setup)
SHADOW_DATABASE_URL=mysql://root:root_secret@localhost:3306/billing_db_shadow

# --- Redis (matches docker-compose redis service) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Billing / stock behaviour ---
RESERVATION_INACTIVITY_MINUTES=30
BATCH_BLOCK_EXPIRED=true
INVOICE_STORAGE_PATH=storage/invoices

# --- Customer portal OTP (dev: OTP printed in backend console) ---
SMS_PROVIDER=console
CUSTOMER_OTP_EXPIRY_MINUTES=10
CUSTOMER_OTP_REQUEST_COOLDOWN_MINUTES=15
CUSTOMER_OTP_MAX_REQUESTS_PER_WINDOW=3
CUSTOMER_OTP_DEV_EXPOSE=true

# --- Frontend (local dev: Next proxies /api/v1 → Nest) ---
# Use /api/v1 for same-origin cookies after refresh (recommended with npm run dev).
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
BACKEND_INTERNAL_URL=http://127.0.0.1:4000

# --- Docker full stack (nginx on port 80) ---
NGINX_HTTP_PORT=80

# --- Optional (frontend dev scripts; defaults work if omitted) ---
# BACKEND_WAIT_ATTEMPTS=120
# BACKEND_WAIT_INITIAL_MS=5000
# NEXT_DIST_DIR=.next
