NODE_ENV=development
BACKEND_PORT=4000
API_PREFIX=api
DATABASE_URL=mysql://billing:billing_secret@localhost:3306/billing_db
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
CORS_ORIGIN=http://localhost:3000

# Customer forgot-password OTP (SMS_PROVIDER=console logs OTP to server until SMS API is wired)
SMS_PROVIDER=console
CUSTOMER_OTP_EXPIRY_MINUTES=10
CUSTOMER_OTP_REQUEST_COOLDOWN_MINUTES=15
CUSTOMER_OTP_MAX_REQUESTS_PER_WINDOW=3
CUSTOMER_OTP_DEV_EXPOSE=true
