{
  "name": "@billing/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "clean": "node scripts/clean-dist.mjs",
    "predev": "node scripts/ensure-shared-built.mjs",
    "dev": "node scripts/kill-port.mjs 4000 && nest start --watch",
    "predev:fresh": "node scripts/ensure-shared-built.mjs",
    "dev:fresh": "node scripts/kill-port.mjs 4000 && node scripts/clean-dist.mjs && nest build && nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:apply": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "prisma:seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "prisma:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "prisma:recover": "node scripts/prisma-recover.mjs",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@billing/shared": "*",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.0.11",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.11",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.41.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.5.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.11",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
